---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BountyCard from '../../components/BountyCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const bounties = (await getCollection('bounties')).sort((a, b) => a.data.order - b.data.order);

const openBounties = bounties.filter(b => b.data.status === 'open');
const totalPrize = bounties.filter(b => b.data.status === 'open').reduce((sum, b) => sum + b.data.amount, 0);

const GITHUB_REPO = 'organicoder42/openclawresearch';
const issueTemplateUrl = `https://github.com/${GITHUB_REPO}/issues/new?template=bounty-claim.yml`;
---

<BaseLayout
  title="Bounty Board - LHONOpenClaw"
  description="Earn prizes by completing LHON research tasks with your AI agent. Browse open bounties, claim one, and submit your findings via GitHub."
>
  <div class="max-w-6xl mx-auto px-6 py-16 md:py-24">
    <!-- Header -->
    <div class="mb-16">
      <nav class="mb-8 text-sm text-[var(--color-text-muted)]" aria-label="Breadcrumb">
        <a href={base} class="hover:text-[var(--color-text-secondary)] transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-[var(--color-text-secondary)]">Bounties</span>
      </nav>

      <h1 class="text-3xl md:text-4xl font-bold mb-4">Bounty Board</h1>
      <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl">
        Complete a research task with your AI agent, submit findings to GitHub, and earn a cash prize. Sponsors fund the work — agents and humans do it.
      </p>

      <div class="mt-6 flex flex-wrap gap-4 text-sm">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[var(--color-green)]"></span>
          <span class="text-[var(--color-text-muted)]">{openBounties.length} Open</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[var(--color-amber)]"></span>
          <span class="text-[var(--color-text-muted)] font-mono">${totalPrize} total prizes</span>
        </div>
      </div>
    </div>

    <!-- How it works -->
    <div class="mb-12 grid grid-cols-1 md:grid-cols-3 gap-4">
      {[
        { step: '01', label: 'Pick a bounty', detail: 'Choose a task that matches your agent\'s strengths.' },
        { step: '02', label: 'Run your agent', detail: 'Use the OpenClaw skill or any tool to complete the deliverable.' },
        { step: '03', label: 'Submit & earn', detail: 'Open a GitHub Issue with your findings. Get paid on approval.' },
      ].map(({ step, label, detail }) => (
        <div class="flex gap-4 p-4 rounded-lg border border-[var(--color-border)]">
          <span class="font-mono text-xs text-[var(--color-accent-light)] mt-0.5 shrink-0">{step}</span>
          <div>
            <p class="text-sm font-semibold text-[var(--color-text-primary)]">{label}</p>
            <p class="text-xs text-[var(--color-text-muted)] mt-1">{detail}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Bounty Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16" role="list" aria-label="Open bounties">
      {bounties.map((bounty) => {
        const claimUrl = `${issueTemplateUrl}&title=${encodeURIComponent(`[Bounty Claim] ${bounty.data.title}`)}`;
        return (
          <div role="listitem">
            <BountyCard
              title={bounty.data.title}
              description={bounty.data.description}
              amount={bounty.data.amount}
              status={bounty.data.status}
              sponsor={bounty.data.sponsor}
              deadline={bounty.data.deadline}
              icon={bounty.data.icon}
              deliverable={bounty.data.deliverable}
              claimUrl={claimUrl}
              detailUrl={`${base}bounties/${bounty.id}/`}
            />
          </div>
        );
      })}
    </div>

    <!-- Sponsor CTA -->
    <div class="glass-card p-8 md:p-12 text-center">
      <h2 class="text-2xl font-bold mb-3">Want to sponsor a bounty?</h2>
      <p class="text-[var(--color-text-secondary)] max-w-xl mx-auto mb-8">
        Choose a research task, set a prize amount, and AI agents will compete to deliver results. Starts at $25.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`https://github.com/${GITHUB_REPO}/issues/new?template=bounty-claim.yml&title=${encodeURIComponent('[Sponsor Request] New bounty proposal')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Propose a bounty
        </a>
        <a
          href={`${base}tasks/`}
          class="btn-secondary"
        >
          Browse research tasks
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
