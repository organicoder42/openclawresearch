---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const briefs = await getCollection('briefs');
  return briefs.map((brief) => ({
    params: { slug: brief.id },
    props: { brief },
  }));
}

const base = import.meta.env.BASE_URL;
const { brief } = Astro.props;
const { Content } = await render(brief);
const b = brief.data;
---

<BaseLayout
  title={`${b.title} - LHONOpenClaw`}
  description={b.summary}
>
  <article class="max-w-3xl mx-auto px-6 py-16 md:py-24">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm text-[var(--color-text-muted)]" aria-label="Breadcrumb">
      <a href={base} class="hover:text-[var(--color-text-secondary)] transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href={`${base}briefs/`} class="hover:text-[var(--color-text-secondary)] transition-colors">Briefs</a>
      <span class="mx-2">/</span>
      <span class="text-[var(--color-text-secondary)]">{b.title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-10 pb-8 border-b border-[var(--color-border)]">
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="badge badge-category">{b.topic}</span>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold mb-4 leading-tight">{b.title}</h1>

      <div class="flex flex-wrap gap-4 text-sm text-[var(--color-text-muted)]">
        <span>
          {new Date(b.publishedDate).toLocaleDateString('en-GB', {
            day: 'numeric', month: 'long', year: 'numeric'
          })}
        </span>
        <span>·</span>
        <span>{b.authors.join(', ')}</span>
        <span>·</span>
        <span class="font-mono">Audiences: {b.audiences.join(', ')}</span>
      </div>
    </header>

    <!-- Content -->
    <section class="prose prose-invert max-w-none mb-12
      [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:text-[var(--color-text-primary)]
      [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:mt-6 [&_h3]:mb-2 [&_h3]:text-[var(--color-text-primary)]
      [&_p]:text-[var(--color-text-secondary)] [&_p]:leading-relaxed [&_p]:mb-4
      [&_ul]:space-y-2 [&_ul]:mb-6 [&_ul]:list-disc [&_ul]:pl-6
      [&_ol]:space-y-2 [&_ol]:mb-6 [&_ol]:list-decimal [&_ol]:pl-6
      [&_li]:text-[var(--color-text-secondary)]
      [&_strong]:text-[var(--color-text-primary)]
      [&_a]:text-[var(--color-accent-light)] [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-[var(--color-accent)]
    ">
      <Content />
    </section>

    <!-- Citations -->
    {b.citations.length > 0 && (
      <section class="glass-card p-6 mb-8">
        <h2 class="text-sm font-mono uppercase tracking-wider text-[var(--color-text-muted)] mb-4">Key citations</h2>
        <ol class="space-y-2 text-sm list-decimal pl-6">
          {b.citations.map((c) => (
            <li class="text-[var(--color-text-secondary)]">
              {c.url ? (
                <a href={c.url} target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent-light)] hover:text-[var(--color-accent)] transition-colors">
                  {c.title}
                </a>
              ) : (
                <span>{c.title}</span>
              )}
              {c.doi && (
                <span class="text-[var(--color-text-muted)] ml-2 font-mono text-xs">DOI: {c.doi}</span>
              )}
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- Related findings -->
    {b.relatedFindings.length > 0 && (
      <section class="mb-8">
        <h2 class="text-sm font-mono uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Related project findings</h2>
        <ul class="space-y-2">
          {b.relatedFindings.map((finding) => (
            <li>
              <a href={`${base}results/${finding}/`} class="text-[var(--color-accent-light)] hover:text-[var(--color-accent)] transition-colors">
                {finding} &rarr;
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Share/attribution -->
    <section class="glass-card p-6 mb-8">
      <h2 class="text-sm font-mono uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Cite this brief</h2>
      <p class="text-sm text-[var(--color-text-secondary)] font-mono leading-relaxed">
        LHONOpenClaw ({new Date(b.publishedDate).getFullYear()}). "{b.title}". Research brief. Retrieved from /briefs/{brief.id}/
      </p>
    </section>

    <!-- Back -->
    <a href={`${base}briefs/`} class="btn-secondary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      All briefs
    </a>
  </article>
</BaseLayout>
