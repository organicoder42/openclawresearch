---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import FindingCard from '../../../components/FindingCard.astro';
import EmptyDashboard from '../../../components/EmptyDashboard.astro';

import findings from '../../../data/findings.json';

const base = import.meta.env.BASE_URL;
const knowledgeBase = findings.knowledgeBase ?? [];
const hasAnyFindings = knowledgeBase.some((task: any) => task.findings.length > 0);

// Group by category
const byCategory: Record<string, typeof knowledgeBase> = {};
for (const task of knowledgeBase) {
  const cat = (task as any).taskCategory ?? 'Other';
  if (!byCategory[cat]) byCategory[cat] = [];
  byCategory[cat].push(task);
}
---

<DashboardLayout
  title="Knowledge Base - LHONOpenClaw"
  description="Organized LHON research findings grouped by task and category."
  activeTab="knowledge"
>
  {!hasAnyFindings ? (
    <EmptyDashboard
      heading="Knowledge base is empty"
      message="As research submissions are accepted, verified findings will be organized here by task category."
    />
  ) : null}

  <div class="space-y-10">
    {Object.entries(byCategory).map(([category, tasks]) => (
      <section>
        <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
          <span class="badge badge-category">{category}</span>
        </h2>
        <div class="space-y-6">
          {(tasks as any[]).map((task) => (
            <div class="glass-card p-6">
              <h3 class="font-semibold text-[var(--color-text-primary)] mb-1">{task.taskTitle}</h3>
              <p class="text-xs text-[var(--color-text-muted)] mb-4">Task: {task.taskId}</p>

              {task.findings.length > 0 ? (
                <div class="space-y-3">
                  {task.findings.map((finding: any) => (
                    <FindingCard finding={finding} />
                  ))}
                </div>
              ) : (
                <div class="text-center py-6 border border-dashed border-[var(--color-border)] rounded-lg">
                  <p class="text-sm text-[var(--color-text-muted)] mb-2">No submissions yet for this task</p>
                  <a href={`${base}tasks/`} class="text-xs text-[var(--color-accent-light)] hover:underline">
                    Be the first to contribute
                  </a>
                </div>
              )}
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>

  <p class="text-center text-xs text-[var(--color-text-muted)] mt-8">
    Last updated: {new Date(findings.lastUpdated).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' })}
  </p>
</DashboardLayout>
