---
interface Props {
  title: string;
  description: string;
  amount: number;
  status: string;
  sponsor: { name: string; url?: string };
  deadline: string | null;
  icon: string;
  deliverable: string;
  claimUrl: string;
  detailUrl: string;
}

const { title, description, amount, status, sponsor, deadline, deliverable, claimUrl, detailUrl } = Astro.props;

const statusLabel: Record<string, string> = {
  open: 'Open',
  claimed: 'In progress',
  completed: 'Completed',
};

const statusColor: Record<string, string> = {
  open: 'text-[var(--color-green)]',
  claimed: 'text-[var(--color-amber)]',
  completed: 'text-[var(--color-accent-light)]',
};

const deadlineLabel = deadline
  ? new Date(deadline).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
  : null;
---

<article class="flat-card p-5 flex flex-col h-full border-l-2 border-l-[var(--color-amber)]">
  <div class="flex items-baseline justify-between mb-3">
    <span class={`text-xs font-mono ${statusColor[status] || 'text-[var(--color-text-muted)]'}`}>
      {statusLabel[status] || status}
    </span>
    <span class="text-sm font-mono font-semibold text-[var(--color-text-primary)]">${amount}</span>
  </div>

  <h3 class="text-base font-semibold mb-2">
    <a href={detailUrl} class="text-[var(--color-text-primary)] hover:text-[var(--color-accent-light)] transition-colors">{title}</a>
  </h3>

  <p class="text-sm text-[var(--color-text-secondary)] mb-4 flex-1 leading-relaxed">{description}</p>

  <div class="mb-4 text-xs text-[var(--color-text-muted)]">
    <span class="font-mono">Deliverable:</span> {deliverable}
  </div>

  <div class="flex items-center justify-between pt-3 border-t border-[var(--color-border)]">
    <div class="text-xs text-[var(--color-text-muted)]">
      {sponsor.url
        ? <a href={sponsor.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-text-secondary)] transition-colors">{sponsor.name}</a>
        : <span>{sponsor.name}</span>
      }
      {deadlineLabel && <span class="ml-2">· {deadlineLabel}</span>}
    </div>
    {status === 'open' && (
      <a
        href={claimUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-[var(--color-accent-light)] hover:text-[var(--color-text-primary)] transition-colors"
      >
        Claim &rarr;
      </a>
    )}
    {status === 'completed' && (
      <a href={detailUrl} class="text-sm text-[var(--color-accent-light)] hover:text-[var(--color-text-primary)] transition-colors">
        View results &rarr;
      </a>
    )}
  </div>
</article>
