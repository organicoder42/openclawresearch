---
interface Props {
  title: string;
  description: string;
  amount: number;
  status: string;
  sponsor: { name: string; url?: string };
  deadline: string | null;
  icon: string;
  deliverable: string;
  claimUrl: string;
  detailUrl: string;
}

const { title, description, amount, status, sponsor, deadline, icon, deliverable, claimUrl, detailUrl } = Astro.props;

const statusColor: Record<string, string> = {
  open: 'badge-open',
  claimed: 'badge-sponsor',
  completed: 'badge-category',
};

const deadlineLabel = deadline
  ? new Date(deadline).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
  : null;
---

<article class="glass-card p-6 flex flex-col h-full">
  <div class="flex items-start justify-between mb-4">
    <span class="text-3xl" role="img" aria-hidden="true">{icon}</span>
    <div class="flex gap-2 items-center">
      <span class={`badge ${statusColor[status] ?? 'badge-open'}`}>{status}</span>
      <span class="badge badge-sponsor font-mono">${amount}</span>
    </div>
  </div>

  <h3 class="text-lg font-bold mb-2">
    <a href={detailUrl} class="text-[var(--color-text-primary)] hover:text-[var(--color-accent-light)] transition-colors">{title}</a>
  </h3>

  <p class="text-sm text-[var(--color-text-secondary)] mb-4 flex-1">{description}</p>

  <div class="mb-4 p-3 rounded-lg bg-[var(--color-bg-secondary)] border border-[var(--color-border)]">
    <p class="text-xs text-[var(--color-text-muted)] mb-1 uppercase tracking-wider font-semibold">Deliverable</p>
    <p class="text-xs font-mono text-[var(--color-text-secondary)] leading-relaxed">{deliverable}</p>
  </div>

  <div class="flex items-center justify-between pt-4 border-t border-[var(--color-border)]">
    <div class="text-xs text-[var(--color-text-muted)]">
      {sponsor.url
        ? <a href={sponsor.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-text-secondary)] transition-colors">{sponsor.name}</a>
        : <span>{sponsor.name}</span>
      }
      {deadlineLabel && <span class="ml-2 font-mono">· {deadlineLabel}</span>}
    </div>
    {status === 'open' && (
      <a
        href={claimUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-[var(--color-cyan)] hover:text-[var(--color-accent-light)] transition-colors"
      >
        Claim &rarr;
      </a>
    )}
    {status === 'claimed' && (
      <span class="text-xs font-mono text-[var(--color-amber)]">In progress</span>
    )}
    {status === 'completed' && (
      <span class="text-xs font-mono text-[var(--color-green)]">Completed</span>
    )}
  </div>
</article>
