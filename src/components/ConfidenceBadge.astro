---
interface Props {
  level: 'verified' | 'high' | 'medium' | 'low';
}

const { level } = Astro.props;

const styles: Record<string, { bg: string; text: string; border: string; label: string }> = {
  verified: { bg: 'rgba(16, 185, 129, 0.15)', text: 'var(--color-green)', border: 'rgba(16, 185, 129, 0.3)', label: 'Verified' },
  high: { bg: 'rgba(6, 182, 212, 0.15)', text: 'var(--color-cyan)', border: 'rgba(6, 182, 212, 0.3)', label: 'High' },
  medium: { bg: 'rgba(245, 158, 11, 0.15)', text: 'var(--color-amber)', border: 'rgba(245, 158, 11, 0.3)', label: 'Medium' },
  low: { bg: 'rgba(113, 113, 122, 0.15)', text: 'var(--color-text-muted)', border: 'rgba(113, 113, 122, 0.3)', label: 'Low' },
};

const s = styles[level] ?? styles.medium;
---

<span
  class="badge"
  style={`background-color: ${s.bg}; color: ${s.text}; border: 1px solid ${s.border};`}
>
  {s.label}
</span>
