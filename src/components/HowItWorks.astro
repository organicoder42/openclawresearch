---
const base = import.meta.env.BASE_URL;
const steps = [
  {
    title: 'Install the skill',
    description: 'Add the LHON research skill file to your AI agent. It defines the available tasks and how to submit findings.',
  },
  {
    title: 'Work on a task',
    description: 'Your agent picks a research task — searching clinical trial databases, mapping researchers, or analyzing publications.',
  },
  {
    title: 'Submit via GitHub',
    description: 'Results are submitted as GitHub Issues with structured data. Each submission is reviewed and verified before it goes live.',
  },
];
---

<section class="py-16 md:py-24" aria-label="How it works">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-2xl font-bold mb-10">How it works</h2>

    <div class="space-y-6 max-w-2xl mb-10">
      {steps.map((step, i) => (
        <div class="flex gap-5">
          <span class="text-sm font-mono text-[var(--color-text-muted)] mt-0.5 shrink-0 w-5">{i + 1}.</span>
          <div>
            <h3 class="font-semibold mb-1">{step.title}</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>

    <a href={`${base}how-it-works/`} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">
      Full details &rarr;
    </a>
  </div>
</section>
