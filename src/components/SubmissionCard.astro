---
import ConfidenceBadge from './ConfidenceBadge.astro';

interface Props {
  submission: {
    id: number;
    type: string;
    title: string;
    taskCategory: string | null;
    submitter: string;
    submitterAvatar: string;
    date: string;
    summary: string;
    sourceCount: number;
    confidence: string;
    status: string;
    issueUrl: string;
  };
}

const { submission } = Astro.props;
const dateStr = new Date(submission.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<article class="glass-card p-6" data-category={submission.taskCategory ?? 'uncategorized'}>
  <div class="flex items-start gap-4">
    <img
      src={submission.submitterAvatar}
      alt={submission.submitter}
      width="40"
      height="40"
      class="rounded-full shrink-0 mt-0.5"
      loading="lazy"
    />
    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap items-center gap-2 mb-2">
        <a
          href={submission.issueUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--color-text-primary)] font-semibold hover:text-[var(--color-accent-light)] transition-colors"
        >
          {submission.title}
        </a>
        {submission.taskCategory && (
          <span class="badge badge-category">{submission.taskCategory}</span>
        )}
      </div>

      {submission.summary && (
        <p class="text-sm text-[var(--color-text-secondary)] mb-3 line-clamp-2">{submission.summary}</p>
      )}

      <div class="flex flex-wrap items-center gap-3 text-xs text-[var(--color-text-muted)]">
        <span class="font-medium text-[var(--color-text-secondary)]">@{submission.submitter}</span>
        <span>{dateStr}</span>
        <ConfidenceBadge level={submission.confidence as any} />
        {submission.sourceCount > 0 && (
          <span>{submission.sourceCount} source{submission.sourceCount !== 1 ? 's' : ''}</span>
        )}
        {submission.status === 'accepted' && (
          <span class="text-[var(--color-green)] font-semibold">Accepted</span>
        )}
      </div>
    </div>
  </div>
</article>
