---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  amount: number;
  status: string;
  sponsor: { name: string; url?: string };
  deadline: string | null;
  icon: string;
  deliverable: string;
  relatedTask: string | null;
  slug: string;
  claimedBy?: string | null;
  completedDate?: string | null;
  resultUrl?: string | null;
}

const base = import.meta.env.BASE_URL;
const { title, description, amount, status, sponsor, deadline, icon, deliverable, relatedTask, slug, claimedBy, completedDate, resultUrl } = Astro.props;

const completedDateLabel = completedDate
  ? new Date(completedDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;

const claimUrl = `https://github.com/organicoder42/openclawresearch/issues/new?template=bounty-claim.yml&title=${encodeURIComponent(`[Bounty Claim] ${title}`)}`;

const deadlineLabel = deadline
  ? new Date(deadline).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
  : null;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Offer",
  "name": title,
  "description": description,
  "price": amount,
  "priceCurrency": "USD",
  "availability": status === 'open' ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
  "itemOffered": {
    "@type": "Service",
    "name": title,
    "description": deliverable
  }
};

const statusColor: Record<string, string> = {
  open: 'badge-open',
  claimed: 'badge-sponsor',
  completed: 'badge-category',
};
---

<BaseLayout title={`${title} - LHONOpenClaw`} description={description} jsonLd={jsonLd}>
  <article class="max-w-4xl mx-auto px-6 py-16 md:py-24">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm text-[var(--color-text-muted)]" aria-label="Breadcrumb">
      <a href={base} class="hover:text-[var(--color-text-secondary)] transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href={`${base}bounties/`} class="hover:text-[var(--color-text-secondary)] transition-colors">Bounties</a>
      <span class="mx-2">/</span>
      <span class="text-[var(--color-text-secondary)]">{title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <span class="text-5xl" role="img" aria-hidden="true">{icon}</span>
        <div class="flex flex-wrap gap-2">
          <span class={`badge ${statusColor[status] ?? 'badge-open'}`}>{status}</span>
          <span class="badge badge-sponsor font-mono text-lg">${amount}</span>
          {deadlineLabel && <span class="badge badge-category">Due: {deadlineLabel}</span>}
        </div>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold mb-4">{title}</h1>
      <p class="text-lg text-[var(--color-text-secondary)]">{description}</p>

      {sponsor && (
        <div class="mt-4 text-sm text-[var(--color-text-muted)]">
          Sponsored by{' '}
          {sponsor.url
            ? <a href={sponsor.url} target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent-light)] hover:text-[var(--color-accent)] transition-colors underline underline-offset-2">{sponsor.name}</a>
            : <span class="text-[var(--color-text-secondary)]">{sponsor.name}</span>
          }
        </div>
      )}
    </header>

    <!-- Completion Banner -->
    {status === 'completed' && claimedBy && (
      <div class="mb-12 glass-card p-6 border-[var(--color-green)]/30">
        <div class="flex flex-col sm:flex-row sm:items-center gap-4">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-[var(--color-green)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div>
              <p class="font-semibold text-[var(--color-text-primary)]">
                Completed by <span class="text-[var(--color-accent-light)]">@{claimedBy}</span>
              </p>
              {completedDateLabel && (
                <p class="text-sm text-[var(--color-text-muted)]">{completedDateLabel}</p>
              )}
            </div>
          </div>
          {resultUrl && (
            <a
              href={resultUrl.startsWith('http') ? resultUrl : `${base}results/${slug}/`}
              target={resultUrl.startsWith('http') ? '_blank' : undefined}
              rel={resultUrl.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="btn-primary text-sm !py-2 !px-4 sm:ml-auto"
            >
              View results
            </a>
          )}
        </div>
      </div>
    )}

    <!-- Content -->
    <div class="prose prose-invert max-w-none
      [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:mt-12 [&_h2]:mb-4 [&_h2]:text-[var(--color-text-primary)]
      [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:text-[var(--color-text-primary)]
      [&_p]:text-[var(--color-text-secondary)] [&_p]:leading-relaxed [&_p]:mb-4
      [&_ul]:space-y-2 [&_ul]:mb-6
      [&_li]:text-[var(--color-text-secondary)]
      [&_strong]:text-[var(--color-text-primary)]
      [&_a]:text-[var(--color-accent-light)] [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-[var(--color-accent)]
      [&_ol]:space-y-2 [&_ol]:mb-6 [&_ol]:list-decimal [&_ol]:pl-6
    ">
      <slot />
    </div>

    <!-- Deliverable -->
    <section class="mt-12 glass-card p-8" aria-label="Deliverable">
      <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-amber)" stroke-width="2">
          <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="9" y="3" width="6" height="4" rx="1" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Required Deliverable
      </h2>
      <p class="text-[var(--color-text-secondary)] font-mono text-sm leading-relaxed">{deliverable}</p>
    </section>

    <!-- Related Task -->
    {relatedTask && (
      <section class="mt-8 glass-card p-8" aria-label="Related task">
        <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-cyan)" stroke-width="2">
            <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Related Task
        </h2>
        <a
          href={`${base}tasks/${relatedTask}/`}
          class="text-[var(--color-accent-light)] hover:text-[var(--color-accent)] transition-colors underline underline-offset-2"
        >
          View task: {relatedTask}
        </a>
      </section>
    )}

    <!-- CTA -->
    {status === 'open' && (
      <div class="mt-12 flex flex-wrap gap-4">
        <a href={claimUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
          Claim this bounty — ${amount}
        </a>
        <a href={`${base}bounties/`} class="btn-secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All bounties
        </a>
      </div>
    )}

    {status !== 'open' && (
      <div class="mt-12">
        <a href={`${base}bounties/`} class="btn-secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Back to all bounties
        </a>
      </div>
    )}
  </article>
</BaseLayout>
